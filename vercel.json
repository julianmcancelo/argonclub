{
  "buildCommand": "bash vercel_build.sh",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/bixplay-api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    },
    {
      "source": "/bixplay-search/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    },
    {
      "source": "/vimeus-api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    },
    {
      "source": "/vimeus-embed/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    },
    {
      "source": "/bixplay-server/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/bixplay-api/(.*)",
      "destination": "https://appnew2.bixplay.online/rest-api/v100/$1"
    },
    {
      "source": "/bixplay-search/(.*)",
      "destination": "https://appnew2.bixplay.online/api/$1"
    },
    {
      "source": "/vimeus-api/(.*)",
      "destination": "https://vimeus.com/api/$1"
    },
    {
      "source": "/vimeus-embed/(.*)",
      "destination": "https://vimeus.com/e/$1"
    },
    {
      "source": "/bixplay-server/(.*)",
      "destination": "https://server.bixplay.online/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
